{
  "name": "example-sveltekit-auth",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "depcheck": "npx knip",
    "prepack": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "start": "vite dev",
    "test": "playwright test"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.56.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@zitadel/sveltekit-auth": "^1.1.2",
    "openid-client": "^6.6.3"
  },
  "overrides": {
    "cookie": "^1.0.2"
  }
}

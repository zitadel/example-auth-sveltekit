{
  "name": "example-sveltekit-auth",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "depcheck": "npx knip",
    "prepack": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "prepare": "svelte-kit sync || echo ''",
    "preview": "vite preview",
    "start": "vite dev",
    "test": "playwright test"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^1.2.5",
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.3.0",
    "knip": "^5.64.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^4.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.53.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@zitadel/sveltekit-auth": "^1.0.0",
    "openid-client": "^6.6.3"
  },
  "overrides": {
    "cookie": "^1.0.2"
  }
}
